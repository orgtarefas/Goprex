# Copy this file to local.properties and adjust values for your machine.
# Do not commit local.properties.

# Android SDK path on the developer machine.
# Windows example:
sdk.dir=C:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk

# Google Maps Android key restricted in Google Cloud by:
# - Android app package name
# - SHA-1 certificate fingerprint
GOOGLE_MAPS_API_KEY=YOUR_ANDROID_RESTRICTED_GOOGLE_MAPS_API_KEY
